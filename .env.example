# VPS / server IP or domain
VITE_API_BASE_URL=http://YOUR_SERVER_IP:8000
FRONTEND_ORIGIN=http://YOUR_SERVER_IP:5173

# Database (matches docker-compose defaults)
DATABASE_URL=postgresql://mining_user:mining_pass@postgres:5432/mining_ops

# Set to true only when you want to seed initial data, then set back to false
ALLOW_SEED=false
